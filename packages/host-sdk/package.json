{
    "name": "@pangtou/host-sdk",
    "version": "0.1.5",
    "description": "Host SDK contract for Pangtou plugins and console runtimes.",
    "type": "module",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js"
        },
        "./package.json": "./package.json"
    },
    "files": [
        "dist",
        "README.md"
    ],
    "sideEffects": false,
    "scripts": {
        "build": "tsc -p tsconfig.build.json",
        "check:types": "tsc --noEmit -p tsconfig.json"
    },
    "publishConfig": {
        "access": "public"
    }
}

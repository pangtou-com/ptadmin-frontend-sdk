{
    "compilerOptions": {
        "target": "ES2020",
        "module": "ESNext",
        "moduleResolution": "Node",
        "strict": true,
        "skipLibCheck": true,
        "resolveJsonModule": true,
        "esModuleInterop": true,
        "allowSyntheticDefaultImports": true,
        "rootDir": "./src",
        "outDir": "./dist",
        "declaration": true,
        "emitDeclarationOnly": false,
        "noEmit": false
    },
    "include": ["src/**/*.ts"]
}
